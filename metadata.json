{
    "KPackageStructure": "Plasma/Applet",
    "KPlugin": {
        "Id": "wifi-signal-plus",
        "Name": "WiFi Signal Plus",
        "Description": "Displays WiFi generation (4/5/6/7) in the system tray with detailed connection info",
        "Icon": "network-wireless",
        "Version": "1",
        "Authors": [
            {
                "Name": "Jalil Arfaoui",
                "Email": ""
            }
        ],
        "License": "GPL-2.0+",
        "Website": "https://github.com/JalilArfaoui/gnome-extension-wifi-signal-plus",
        "Category": "Network and Connectivity",
        "EnabledByDefault": true
    },
    "X-Plasma-API-Minimum-Version": "6.0",
    "X-Plasma-StandAloneApp": false,
    "X-Plasma-NotificationArea": "true",
    "X-Plasma-NotificationAreaCategory": "Hardware"
}
